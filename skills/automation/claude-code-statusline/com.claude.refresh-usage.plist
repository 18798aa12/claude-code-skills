<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Install:
    cp com.claude.refresh-usage.plist ~/Library/LaunchAgents/
    # Edit the path below to match your $HOME (replace YOUR_USER):
    sed -i '' "s|/Users/YOUR_USER|$HOME|g" ~/Library/LaunchAgents/com.claude.refresh-usage.plist
    launchctl load ~/Library/LaunchAgents/com.claude.refresh-usage.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude.refresh-usage</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/YOUR_USER/.claude/refresh-usage.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>60</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/YOUR_USER/Library/Logs/claude-refresh-usage.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOUR_USER/Library/Logs/claude-refresh-usage.log</string>
</dict>
</plist>
